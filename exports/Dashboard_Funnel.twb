      <column caption='Total Leads' datatype='integer' name='[Calculation_1218822138695682]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([mql_id])' />
      </column>
      <column caption='Converted Leads' datatype='integer' name='[Calculation_1218822138839043]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([converted])' />
      </column>
      <column caption='Conversion Rate' datatype='real' default-format='n#,##0.0;-#,##0.0' name='[Calculation_1218822138970116]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([converted])/COUNT([mql_id])' />
      </column>
      <column caption='Average Days To Convert ' datatype='integer' name='[Calculation_1218822139293701]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF[converted]=1&#13;&#10;THEN DATEDIFF(&apos;day&apos;,[first_contact_date],[won_date])&#13;&#10;END' />
      </column>
      <column caption='AVG(conv)' datatype='real' name='[Calculation_1218822140641286]' role='measure' type='quantitative'>
